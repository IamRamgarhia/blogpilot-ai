# BlogPilot AI — environment variables
# Copy to `.env` (or `.env.local`) and fill in only the providers you want enabled.
# BlogPilot auto-failovers in priority order across whichever keys you set.

# --- Database ---
# Optional. Defaults to ./blogpilot.db in the project root.
# BLOGPILOT_DB_PATH=./blogpilot.db

# --- AI providers: free tier ---
# Google Gemini — https://aistudio.google.com/app/apikey  (1,500 req/day free)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Groq — https://console.groq.com/keys (very fast, generous free tier)
GROQ_API_KEY=

# OpenRouter — https://openrouter.ai/keys (free models routed through)
OPENROUTER_API_KEY=

# Mistral — https://console.mistral.ai/
MISTRAL_API_KEY=

# Cerebras — https://cloud.cerebras.ai/  (ultra-fast inference, free tier)
CEREBRAS_API_KEY=

# Together AI — https://api.together.xyz/
TOGETHER_API_KEY=

# --- AI providers: paid premium ---
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek — https://platform.deepseek.com/  (cheap premium)
DEEPSEEK_API_KEY=

# Perplexity — https://www.perplexity.ai/settings/api  (has built-in web search)
PERPLEXITY_API_KEY=

# --- AI providers: fully local (no key needed) ---
# Ollama — install at https://ollama.com/download then set this to enable
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_ENABLED=1

# LM Studio — install at https://lmstudio.ai/ and run the local server
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# --- Dice Codes (built-in lead capture) ---
# Optional. If set, /api/lead forwards inbound interest to this webhook.
# DICE_LEAD_WEBHOOK=https://hooks.slack.com/services/your/webhook/here

# --- e2e (optional) ---
# Set to 1 to enable the Playwright e2e suite (requires `npx playwright install chromium`).
# BLOGPILOT_E2E=0
# BLOGPILOT_E2E_BASE=http://localhost:3000
